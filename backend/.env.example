# ClamkaBot Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# === DATABASE (Supabase) ===
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# === LLM CONFIG (GitHub Models — FREE) ===
# Get token: https://github.com/settings/tokens → Generate new token (classic)
GITHUB_TOKEN=your_github_pat_token_here
LLM_MODEL=mistral-small-2503
LLM_ENDPOINT=https://models.inference.ai.azure.com

# === APP CONFIG ===
SECRET_KEY=clamkabot-super-secret-jwt-key-2025
MAX_ROWS=1000
QUERY_TIMEOUT=5
